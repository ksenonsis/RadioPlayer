<Window x:Class="RadioPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Radio Player" Height="200" Width="400">


    <Grid>
        <StackPanel Margin="20">

            <TextBox x:Name="UrlBox"
         Height="30"
         Text="http://ice1.somafm.com/groovesalad-128-mp3"/>


            <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,20,0,0">


                <Button Content="Start"
                        Width="100"
                        Click="Start_Click"/>

                <Button Content="Stop"
                        Width="100"
                        Margin="20,0,0,0"
                        Click="Stop_Click"/>

            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
